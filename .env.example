# ═══════════════════════════════════════════════════════════════
# Artha AI — Root Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values.
# This file is for reference only — DO NOT commit real keys!
# ═══════════════════════════════════════════════════════════════

# ─── Supabase ───────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key

# ─── Google AI Studio — Gemini API Keys (3 for rotation) ───────
# Get from: https://aistudio.google.com → Get API Key → Create
# Use 3 different Google accounts for 3x free tier limits
GEMINI_API_KEY_1=your-first-google-ai-studio-key
GEMINI_API_KEY_2=your-second-google-ai-studio-key
GEMINI_API_KEY_3=your-third-google-ai-studio-key

# ─── SMTP (Optional — for fraud email alerts) ──────────────────
# Only needed if you enable email-based fraud alerts to family
# Use a Gmail App Password: https://myaccount.google.com/apppasswords
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password
