# ═══════════════════════════════════════════════════════════════
# Artha AI — Frontend Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your actual values.
#   cp .env.example .env.local
#
# IMPORTANT: .env.local is gitignored — your keys stay safe.
# For Vercel: add these in Dashboard → Settings → Environment Variables
# ═══════════════════════════════════════════════════════════════

# ─── Supabase (Frontend) ────────────────────────────────────────
# VITE_ prefix is REQUIRED — Vite only exposes vars with this prefix
# Get from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key

# ─── Supabase (Serverless Functions — server-side only) ─────────
# These are used by api/ routes and NEVER exposed to the browser
# Get from: Supabase Dashboard → Settings → API → service_role (secret!)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key

# ─── Google AI Studio — Gemini API Keys (3 for rotation) ───────
# Each key gives 15 RPM + 1500 RPD free. 3 keys = 45 RPM + 4500 RPD
# Get from: https://aistudio.google.com → Get API Key → Create API key
# Use 3 DIFFERENT Google accounts for independent free tier quotas
GEMINI_API_KEY_1=your-first-google-ai-studio-key
GEMINI_API_KEY_2=your-second-google-ai-studio-key
GEMINI_API_KEY_3=your-third-google-ai-studio-key

